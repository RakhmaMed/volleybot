TELEGRAM_TOKEN=your_bot_token_here
CHAT_ID=-1001234567890
ADMIN_USER_ID=123456789

# Webhook settings
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your_secret_token
WEBHOOK_PORT=8443
TRUST_PROXY=false

# Application settings
MIN_PLAYERS=12
MAX_PLAYERS=18
RESERVE_PLAYERS=3
POLL_OPTIONS=Да,Нет
SCHEDULER_TIMEZONE=UTC
LOG_LEVEL=INFO

# Payment details shown in final poll/subscription messages (optional)
PAYMENT_NAME=
PAYMENT_BANK=
PAYMENT_PHONE=

# Database path (optional)
# VOLLEYBOT_DB_PATH=data/volleybot.db
